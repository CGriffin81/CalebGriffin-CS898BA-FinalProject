  "ocr_priority_explanation": {
    "0": "Not OCR'd (artwork)",
    "1": "Card name — primary identification signal, sufficient alone for Scryfall fuzzy match",
    "2": "Collector info — enables exact printing identification (set + number)",
    "3": "Type line — disambiguates same-name cards, confirms category",
    "4": "Power/Toughness — confirms creature stats",
    "5": "Rules text — cross-reference validation with Scryfall oracle",
    "6": "Mana cost — confirms color identity (symbol detection, not text OCR)",
    "7": "Set symbol — rarity detection by color (not text OCR)",
    "8": "Artist credit — lowest priority, rarely needed for identification"
  },
  "fallback_strategies": {
    "full_bitmap_spatial": "Run ML Kit on full bitmap, assign text by spatial position relative to anatomy regions",
    "name_only_fuzzy": "Extract only the card name, use Scryfall fuzzy name match for identification",
    "region_decomposition": "Crop each region independently and run ML Kit per-region (requires good alignment)"
  },
  "normalization_rules": {
    "expansion_translation": {
      "formula": "abs_pos = card_start + norm_pos × card_range",
      "card_start": "expansion / (1 + 2×expansion) = 0.1429 for 20% expansion",
      "card_end": "(1 + expansion) / (1 + 2×expansion) = 0.8571 for 20% expansion",
      "card_range": "card_end - card_start = 0.7143"
    },
    "minimum_region_height_px": 40,
    "minimum_region_width_px": 50,
    "ml_kit_requires_context": "Regions < 40px tall often produce zero text blocks"
  }
}
